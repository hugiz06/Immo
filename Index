async function runMatching(clientId) {
if (db.biens.length === 0) { alert(“Ajoutez des biens d’abord !”); return; }
const client = db.clients.find(c => c.id === clientId);
if (!client) return;

aiLoading = true;
matchResult = null;
setTab(“matching”);

const prompt = `Tu es un expert en rapprochement immobilier.

CLIENT :

- Nom : ${client.nom}
- Budget max : ${client.budget} €
- Type recherché : ${client.type}
- Surface min : ${client.surfaceMin} m²
- Secteur(s) : ${client.secteurs}
- Critères spéciaux : ${client.notes || “aucun”}

BIENS DISPONIBLES :
${JSON.stringify(db.biens.map(b => ({
id:b.id, ref:b.ref, type:b.type, prix:b.prix,
surface:b.surface, secteur:b.secteur, pieces:b.pieces,
etat:b.etat, description:b.description
})))}

Pour CHAQUE bien, génère un objet JSON avec :

- id
- score (0-100)
- verdict : “Excellent match” | “Bon match” | “Match partiel” | “Non compatible”
- points_forts : tableau 2-3 phrases courtes
- points_faibles : tableau 0-2 phrases courtes
- conseil : phrase d’accroche commerciale pour pitcher ce bien

Réponds UNIQUEMENT avec un tableau JSON valide, sans texte ni balises.`;

try {
const res = await fetch(“https://api.anthropic.com/v1/messages”, {
method: “POST”,
headers: { “Content-Type”: “application/json” },
body: JSON.stringify({
model: “claude-sonnet-4-20250514”,
max_tokens: 1000,
messages: [{ role:“user”, content: prompt }]
})
});
const data = await res.json();
const raw = (data.content||[]).map(b=>b.text||””).join(””);
const clean = raw.replace(/`json|`/g,””).trim();
const parsed = JSON.parse(clean);
const sorted = parsed.sort((a,b) => b.score - a.score);

```
matchResult = { clientId, results: sorted };
const entry = {
  id: uid(), clientId, date: new Date().toISOString(),
  topScore: sorted[0]?.score || 0,
